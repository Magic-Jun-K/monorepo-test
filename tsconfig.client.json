{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json", // 继承基础配置
  "compilerOptions": {
    /* 基本选项 */
    "target": "ES2020", // 指定 ECMAScript 目标版本
    "module": "ESNext", // 指定生成的模块格式
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"], // 指定要包含在编译中的库文件
    "jsx": "react-jsx", // 指定 JSX 代码生成方案（React 17+）
    "noEmit": true, // 不生成输出文件（由打包工具处理）
    "allowJs": true, // 允许编译 JavaScript 文件
    "allowImportingTsExtensions": true, // 允许导入 .ts 扩展名
    "useDefineForClassFields": true, // 使用 define 语义处理类字段
    "isolatedModules": true, // 确保每个文件都可以安全地转译，而不需要依赖其他文件的信息
    "moduleDetection": "force", // 强制模块检测

    /* 严格检查选项 */
    "strict": true, // 启用所有严格的类型检查选项
    "noUnusedLocals": true, // 报告未使用的局部变量错误
    "noUnusedParameters": true, // 报告未使用的函数参数错误
    "noFallthroughCasesInSwitch": true, // 报告 switch 语句中 fallthrough 的错误
    "noUncheckedIndexedAccess": true, // 对索引签名访问时添加 undefined 类型
    "exactOptionalPropertyTypes": true, // 启用精确可选属性类型
    "verbatimModuleSyntax": false, // 不启用逐字模块语法

    /* 模块解析选项 */
    "moduleResolution": "bundler", // 指定模块解析策略（适用于打包工具）
    "baseUrl": ".", // 指定基础目录以解析非相对模块名
    "paths": {
      "@/*": ["./src/*"],
      "@eggshell/*": ["./packages/*/src"],
      "@frontend/*": ["./apps/frontend/*/src"],
      "@web/*": ["./apps/web/*/src"]
    }, // 指定模块名到基于 baseUrl 的路径映射
    "resolveJsonModule": true, // 允许导入 .json 文件
    "allowSyntheticDefaultImports": true, // 允许从没有默认导出的模块中进行默认导入
    "esModuleInterop": true, // 启用 esModuleInterop 以提供与 CommonJS 模块的互操作性
    "forceConsistentCasingInFileNames": true, // 确保文件名大小写一致

    /* 其他选项 */
    "skipLibCheck": true, // 跳过对声明文件的类型检查
    "removeComments": false, // 保留注释信息
    "incremental": false, // 不启用增量编译
    "types": ["node"] // 添加类型声明文件
  },
  // 指定需要编译的文件
  "include": [
    "apps/frontend/**/*",
    "apps/web/**/*",
    "packages/ui/**/*",
    "packages/antd-ui/**/*",
    "packages/unocss-ui/**/*",
    "packages/unocss-ui-ie/**/*",
    "packages/core-business-components/**/*",
    "**/*.d.ts"
  ],
  // 指定需要排除的文件
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "apps/backend/**/*"
  ]
}