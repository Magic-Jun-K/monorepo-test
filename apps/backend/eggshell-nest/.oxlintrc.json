{
  "extends": ["../../../.oxlintrc.json"],
  "env": {
    "node": true,
    "jest": true
  },
  "ignorePatterns": [
    "dist/**/*",
    "build/**/*",
    "node_modules/**/*",
    ".eslintrc.js"
  ],
  "rules": {
    "no-console": "warn",
    "typescript/no-unused-vars": "error",
    "typescript/no-explicit-any": "warn",
    "typescript/no-floating-promises": "warn"
  }
}