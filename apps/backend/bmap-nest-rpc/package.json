{
  "name": "@backend/bmap-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "compress-images": "ts-node src/scripts/compress-images.ts",
    "proto:generate": "protoc -I=./src/proto --plugin=protoc-gen-ts_proto=\"node_modules\\.bin\\protoc-gen-ts_proto.CMD\" --ts_proto_out=./src/generated --ts_proto_opt=nestJs=true ./src/proto/*.proto",
    "test:grpc": "npx ts-node -r tsconfig-paths/register src/test-grpc.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.2",
    "@nestjs/core": "11.1.2",
    "@nestjs/platform-express": "11.1.2",
    "@nestjs/config": "4.0.2",
    "@nestjs/typeorm": "11.0.0",
    "@nestjs/serve-static": "5.0.3",
    "@nestjs/passport": "11.0.5",
    "@nestjs/jwt": "11.0.0",
    "@nestjs-modules/ioredis": "2.0.2",
    "@nestjs/microservices": "11.1.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.24",
    "pg": "8.16.0",
    "multer": "2.0.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "nanoid": "5.1.5",
    "argon2": "0.43.0",
    "sharp": "0.34.2",
    "file-type": "21.0.0",
    "zod": "3.25.32",
    "ioredis": "5.6.1",
    "kafkajs": "2.2.4",
    "@grpc/grpc-js": "1.13.4",
    "@grpc/proto-loader": "0.7.15",
    "protobufjs": "7.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "11.0.5",
    "@nestjs/testing": "11.1.2",
    "@types/express": "5.0.2",
    "@types/jest": "29.5.14",
    "@types/node": "22.15.23",
    "@types/supertest": "6.0.3",
    "@types/pg": "8.15.2",
    "@types/multer": "1.4.12",
    "@typescript-eslint/eslint-plugin": "8.33.0",
    "@typescript-eslint/parser": "8.33.0",
    "eslint": "9.27.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "source-map-support": "0.5.21",
    "supertest": "7.1.1",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "ts-proto": "2.7.0",
    "@protobuf-ts/protoc": "2.11.0",
    "@protobuf-ts/plugin": "2.11.0"
  },
  "copyFiles": [
    {
      "from": "src/proto/*.proto",
      "to": "dist/proto/"
    }
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
