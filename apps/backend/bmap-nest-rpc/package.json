{
  "name": "@backend/bmap-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "pnpm proto:generate && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "compress-images": "ts-node src/scripts/compress-images.ts",
    "proto:generate": "protoc -I=./src/proto --plugin=protoc-gen-ts_proto=\"node_modules\\.bin\\protoc-gen-ts_proto.CMD\" --ts_proto_out=./src/generated --ts_proto_opt=nestJs=true ./src/proto/*.proto",
    "test:grpc": "npx ts-node -r tsconfig-paths/register src/test-grpc.ts",
    "example:process": "curl -X POST http://localhost:7000/example/process -H \"Content-Type: application/json\" -d \"{\\\"data\\\":\\\"test\\\"}\"",
    "test:features": "npx ts-node -r tsconfig-paths/register src/test-features.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.5",
    "@nestjs/core": "^11.1.5",
    "@nestjs/platform-express": "^11.1.5",
    "@nestjs/config": "4.0.2",
    "@nestjs/typeorm": "11.0.0",
    "@nestjs/serve-static": "5.0.3",
    "@nestjs/passport": "11.0.5",
    "@nestjs/jwt": "11.0.0",
    "@nestjs-modules/ioredis": "2.0.2",
    "@nestjs/microservices": "11.1.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "0.3.25",
    "pg": "8.16.3",
    "multer": "2.0.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "nanoid": "5.1.5",
    "argon2": "0.43.1",
    "sharp": "0.34.3",
    "file-type": "21.0.0",
    "zod": "4.0.14",
    "ioredis": "5.7.0",
    "nodemailer": "7.0.5",
    "kafkajs": "2.2.4",
    "cookie-parser": "1.4.7",
    "crystals-kyber-js": "2.3.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.5",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.0",
    "@types/supertest": "^6.0.3",
    "@types/pg": "8.15.5",
    "@types/multer": "2.0.0",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "ts-proto": "2.7.5",
    "@protobuf-ts/protoc": "2.11.1",
    "@protobuf-ts/plugin": "2.11.1"
  },
  "copyFiles": [
    {
      "from": "src/proto/*.proto",
      "to": "dist/proto/"
    }
  ],
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
