{
  "extends": ["../../../.oxlintrc.json"],
  "rules": {
    "no-console": "warn",
    "typescript/no-unused-vars": "error",
    "typescript/no-explicit-any": "warn",
    "typescript/no-floating-promises": "warn",
    "typescript/no-unsafe-argument": "warn"
  },
  "ignore": [
    "dist/**/*",
    "build/**/*",
    "node_modules/**/*",
    "eslint.config.mjs"
  ]
}