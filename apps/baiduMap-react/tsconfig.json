{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "composite": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "module": "ESNext"
  },
  "include": ["src/**/*"], // 指定 需要 编译的文件
  "exclude": ["node_modules", "build", "public"] // 指定 不需要 编译的文件
}
