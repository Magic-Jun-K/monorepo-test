{
  "extends": ["../../../.oxlintrc.json"],
  "env": {
    "browser": true
  },
  "ignore": [
    "dist/**/*",
    "build/**/*",
    "node_modules/**/*",
    "public/**/*",
    "scripts/**/*"
  ],
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-debugger": "warn",
    "typescript/no-unused-vars": "error",
    "react/prop-types": "off",
    "react/react-in-jsx-scope": "off",
    "react/jsx-uses-react": "off"
  }
}