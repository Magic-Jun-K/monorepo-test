{
  "extends": ["../../../.oxlintrc.json"],
  "env": {
    "browser": true
  },
  "ignorePatterns": [
    "dist/**/*",
    "build/**/*",
    "node_modules/**/*",
    "public/**/*",
    "scripts/**/*",
    "webpack.config.mjs",
    "webpack.config.dev.mjs",
    "tailwind.config.mjs",
    "postcss.config.mjs"
  ],
  "rules": {
    "no-console": ["warn", { "allow": ["log", "warn", "error"] }],
    "no-debugger": "warn",
    "typescript/no-unused-vars": "error",
    "react/prop-types": "off",
    "react/react-in-jsx-scope": "off",
    "react/jsx-uses-react": "off"
  }
}