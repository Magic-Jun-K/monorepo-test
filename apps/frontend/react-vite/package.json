{
  "name": "@frontend/react-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:font": "node scripts/font-subset.js",
    "generate:grpc": "node scripts/generate-grpc.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "test": "node tests",
    "start": "npx serve ."
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.7.1",
    "@eggshell/antd-ui": "workspace:*",
    "@eggshell/unocss-ui": "workspace:*",
    "@eggshell/core-business-components": "workspace:*",
    "echarts": "6.0.0",
    "axios": "1.11.0",
    "@sentry/react": "9.44.2",
    "clsx": "2.1.1",
    "react-hook-form": "7.62.0",
    "zod": "4.0.14",
    "@hookform/resolvers": "5.2.1",
    "hash-wasm": "4.12.0",
    "@glideapps/glide-data-grid": "6.0.3",
    "uuid": "11.1.0",
    "web-vitals": "5.1.0",
    "mobx": "6.13.7",
    "mobx-react-lite": "4.1.0",
    "redux": "5.0.1",
    "react-redux": "9.2.0",
    "@reduxjs/toolkit": "2.8.2",
    "antd": "5.26.7",
    "@connectrpc/connect-web": "1.6.1",
    "@connectrpc/connect": "1.6.1",
    "@bufbuild/protobuf": "1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@types/node": "24.2.0",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.0.6",
    "tslib": "2.8.1",
    "rollup-plugin-visualizer": "6.0.3",
    "@vitejs/plugin-react-swc": "3.11.0",
    "vite-plugin-svgr": "4.3.0",
    "vite-plugin-image-optimizer": "2.0.2",
    "terser": "5.43.1",
    "assemblyscript": "0.28.3",
    "vite-plugin-wasm": "3.5.0",
    "sass-embedded": "1.89.2",
    "fontmin": "2.0.3",
    "@types/fontmin": "0.9.5",
    "glob": "11.0.3",
    "@bufbuild/protoc-gen-es": "1.10.1",
    "@bufbuild/buf": "1.56.0",
    "@connectrpc/protoc-gen-connect-es": "1.6.1"
  },
  "exports": {
    ".": {
      "import": "./build/release.js",
      "types": "./build/release.d.ts"
    }
  }
}
