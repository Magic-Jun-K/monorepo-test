{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* 基本选项 */
    "target": "ES2017", // 指定 ECMAScript 目标版本
    "module": "ESNext", // 指定生成的模块格式
    "lib": ["ESNext"], // 指定要包含在编译中的库文件
    "jsx": "preserve", // 指定 JSX 代码生成方案
    "sourceMap": true, // 生成相应的 .map 文件
    "noEmit": true, // 不生成输出文件（由引用的项目处理）
    "rootDir": ".", // 指定 TypeScript 源文件的根目录
    "removeComments": false, // 保留注释信息
    "downlevelIteration": true, // 为迭代器对象提供完整的 ES2015 迭代支持
    "importHelpers": true, // 从 tslib 导入辅助函数，减少代码体积
    "isolatedModules": true, // 确保每个文件都可以安全地转译，而不需要依赖其他文件的信息

    /* 严格检查选项 */
    "strict": true, // 启用所有严格的类型检查选项
    "alwaysStrict": false, // 不为每个源文件生成 "use strict" 指令
    "noImplicitAny": true, // 对隐含的 any 类型的表达式和声明报错
    "noImplicitReturns": true, // 对函数中所有可能的代码路径都要求有返回值
    "noImplicitThis": true, // 当 this 表达式的值为 any 类型时抛出错误
    "noFallthroughCasesInSwitch": true, // 报告 switch 语句中 fallthrough 的错误
    "noUncheckedIndexedAccess": true, // 对索引签名访问时添加 undefined 类型
    "noUnusedLocals": false, // 不报告未使用的局部变量错误
    "noUnusedParameters": false, // 不报告未使用的函数参数错误
    "strictBindCallApply": false, // 不对 bind、call 和 apply 方法进行严格检查
    "strictFunctionTypes": true, // 对函数类型进行更严格的检查
    "strictNullChecks": true, // 启用严格的空值检查
    "strictPropertyInitialization": true, // 启用类属性初始化的严格检查
    "useUnknownInCatchVariables": true, // 在 catch 子句中的变量使用 unknown 类型

    /* 模块解析选项 */
    // "moduleResolution": "node", // 指定模块解析策略
    "moduleResolution": "bundler", // 指定模块解析策略
    "baseUrl": ".", // 指定基础目录以解析非相对模块名
    "paths": {
      "@/*": ["./src/*"],
      "@eggshell/*": ["./packages/*/src"],
      "@frontend/*": ["./apps/frontend/*/src"],
      "@backend/*": ["./apps/backend/*/src"],
      "@web/*": ["./apps/web/*/src"]
    }, // 指定模块名到基于 baseUrl 的路径映射
    "resolveJsonModule": true, // 允许导入 .json 文件
    "allowSyntheticDefaultImports": true, // 允许从没有默认导出的模块中进行默认导入
    "esModuleInterop": true, // 启用 esModuleInterop 以提供与 CommonJS 模块的互操作性
    "forceConsistentCasingInFileNames": true, // 确保文件名大小写一致

    /* 实验性选项 */
    "experimentalDecorators": true, // 启用对装饰器的实验性支持
    "emitDecoratorMetadata": true, // 启用对装饰器元数据的实验性支持

    /* 其他选项 */
    "allowJs": false, // 不允许编译 JavaScript 文件
    "checkJs": false, // 不检查 JavaScript 文件中的错误
    "allowUnreachableCode": false, // 不允许无法访问的代码
    "allowUnusedLabels": false, // 不允许未使用的标签
    "exactOptionalPropertyTypes": false, // 不启用精确可选属性类型
    "noErrorTruncation": true, // 不截断错误信息
    "preserveWatchOutput": true, // 保留监视输出
    "skipLibCheck": true // 跳过对声明文件的类型检查
  },
  // 指定需要编译的文件
  "include": [
    "*.ts",
    "**/*.d.ts",
    "packages/**/src/**/*.ts",
    "packages/**/src/**/*.test.ts",
    "packages/**/src/**/*.spec.ts",
    "cspell.config.ts"
  ],
  // 指定需要排除的文件
  "exclude": ["node_modules", "dist", "build", "coverage"]
}