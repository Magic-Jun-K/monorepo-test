# EditorConfig 配置文件
# 统一团队编辑器设置，提高代码一致性
# 更多信息：https://editorconfig.org

# 项目根目录标识
root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript/TypeScript 文件
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON 文件
[*.json]
indent_style = space
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# HTML 文件
[*.html]
indent_style = space
indent_size = 2

# CSS/SCSS/LESS 文件
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Go 文件
[*.go]
indent_style = tab
indent_size = 4

# Makefile
[Makefile]
indent_style = tab

# 包管理器锁文件
[{package-lock.json,pnpm-lock.yaml,yarn.lock}]
indent_style = space
indent_size = 2
insert_final_newline = false

# 配置文件
[*.{toml,ini}]
indent_style = space
indent_size = 2

# Shell 脚本
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf