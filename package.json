{
  "name": "monorepo-test",
  "version": "0.0.0",
  "description": "monorepo-test",
  "keywords": [],
  "license": "ISC",
  "author": "Magic-Jun-K",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "dev:react-webpack": "turbo dev:react-webpack",
    "dev:react-webpack2": "pnpm --filter @web/react-webpack dev",
    "build": "turbo build",
    "build:react-webpack": "turbo build:react-webpack",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "test:unit": "turbo test:unit",
    "test:e2e": "turbo test:e2e",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "test:backend": "pnpm test:eggshell-nest",
    "test:packages": "vitest run packages",
    "test:react-vite": "pnpm --filter @frontend/react-vite test",
    "test:react-webpack": "pnpm --filter @web/react-webpack test",
    "test:eggshell-nest": "pnpm --filter @api/eggshell-nest test",
    "test:ui": "pnpm --filter @eggshell/ui test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rimraf node_modules/.cache",
    "docker:start": "docker compose -f infra/docker/react-webpack_nest/docker-compose.yml up -d",
    "docker:stop": "docker compose -f infra/docker/react-webpack_nest/docker-compose.yml down",
    "lint": "turbo lint",
    "lint:es": "eslint packages/**/*.ts apps/**/*.ts",
    "lint:fix": "turbo lint:ox -- --fix && turbo lint:style -- --fix",
    "lint:ox": "turbo lint:ox",
    "lint:ox:fix": "turbo lint:ox -- --fix",
    "lint:style": "turbo lint:style",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(mjs|ts|tsx|css|scss|md)\"",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:status": "changeset status",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:dry": "pnpm build && changeset publish --dry-run",
    "release:private": "pnpm build && changeset publish --registry https://npm.pkg.github.com",
    "release:npm": "pnpm build && changeset publish --registry https://registry.npmjs.org",
    "setup:github-packages": "echo '@eggshell:registry=https://npm.pkg.github.com' > .npmrc && echo '//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}' >> .npmrc",
    "prepare": "husky",
    "commit": "git-cz",
    "format:check": "turbo format -- --check",
    "format": "turbo format"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@vitest/coverage-v8": "^4.1.3",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.0",
    "cspell": "^10.0.0",
    "cz-git": "^1.12.0",
    "eslint": "^10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "stylelint": "^17.6.0",
    "turbo": "^2.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "^18",
        "react-dom": "^18"
      }
    },
    "overrides": {
      "@types/react": "^18",
      "@types/react-dom": "^18"
    }
  }
}
