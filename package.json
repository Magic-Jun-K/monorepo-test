{
  "name": "canvaskit-react-test",
  "version": "0.0.1",
  "packageManager": "pnpm@9.14.2",
  "main": "index.js",
  "scripts": {
    "lint:es": "eslint packages/**/*.ts",
    "lint:style": "stylelint \"(packages|apps)/**/*.css\"",
    "lint": "pnpm lint:es && pnpm lint:style",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "prepare": "husky",
    "commit": "git-cz",
    "dev": "turbo dev:baiduMap",
    "build": "turbo build:baiduMap"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "pnpm spellcheck"
    ],
    "*.css": [
      "stylelint --fix",
      "pnpm spellcheck"
    ]
  },
  "devDependencies": {
    "eslint": "9.16.0",
    "@eslint/js": "9.16.0",
    "typescript": "5.7.2",
    "typescript-eslint": "8.17.0",
    "cspell": "8.16.0",
    "stylelint": "16.10.0",
    "husky": "9.1.7",
    "commitlint": "19.6.0",
    "cz-git": "1.11.0",
    "commitizen": "4.3.1",
    "@commitlint/config-conventional": "19.6.0",
    "lint-staged": "15.2.10",
    "turbo": "2.3.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
