{
  "name": "canvaskit-react-test",
  "version": "0.0.1",
  "packageManager": "pnpm@10.11.0",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "dev:react-webpack": "turbo dev:react-webpack",
    "dev:react-webpack2": "pnpm --filter @frontend/react-webpack dev",
    "build": "turbo build:react-webpack",
    "docker:start": "docker compose -f .devcontainer/docker-compose.yml up -d",
    "docker:stop": "docker compose -f .devcontainer/docker-compose.yml down",
    "docker:deploy": "docker compose -f .devcontainer/docker-compose.deploy.yml up -d",
    "docker:build-deploy": "pnpm build && pnpm docker:deploy",
    "docker:deploy:stop": "docker compose -f .devcontainer/docker-compose.deploy.yml down",
    "lint:es": "eslint packages/**/*.ts",
    "lint:style": "stylelint \"(packages|apps)/**/*.css\"",
    "lint": "pnpm lint:es && pnpm lint:style",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.css": [
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "eslint": "9.27.0",
    "@eslint/js": "9.27.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "cspell": "9.0.1",
    "stylelint": "16.19.1",
    "husky": "9.1.7",
    "commitlint": "19.8.1",
    "cz-git": "1.11.1",
    "commitizen": "4.3.1",
    "@commitlint/config-conventional": "19.8.1",
    "lint-staged": "16.0.0",
    "turbo": "2.5.3",
    "fast-glob": "3.3.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
