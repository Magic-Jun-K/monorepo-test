{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "start:dev": {
      "cache": true,
      "persistent": false
    },
    "dev:react-webpack": {
      "dependsOn": ["start:dev"],
      "cache": true,
      "persistent": false
    },
    "build:react-webpack": {
      "cache": true,
      "persistent": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
