{
  "name": "@eggshell/core-business-components",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./lib/es/index.js",
  "module": "./lib/es/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/es/index.js"
    },
    "./wasm/*": "./lib/wasm/*"
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Magic-Jun-K/monorepo-test.git",
    "directory": "packages/core-business-components"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "vite",
    "build:workers": "tsc -p tsconfig.worker.json",
    "build": "tsc -b && pnpm build:workers && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "pnpm asbuild:debug && pnpm asbuild:release",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "npx serve ."
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@eggshell/unocss-ui": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "18.3.24",
    "@types/react-dom": "18.3.7",
    "@types/node": "24.4.0",
    "@testing-library/react": "^16.0.1",
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "vite-plugin-wasm": "3.5.0",
    "vite-plugin-dts": "4.5.4",
    "assemblyscript": "0.28.8",
    "tslib": "2.8.1"
  }
}