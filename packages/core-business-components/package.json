{
  "name": "@eggshell/core-business-components",
  "version": "0.0.0",
  "private": true,
  "description": "核心业务组件库",
  "keywords": [],
  "license": "ISC",
  "author": "Magic-Jun-K",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Magic-Jun-K/monorepo-test.git",
    "directory": "packages/core-business-components"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.es.js",
  "module": "./lib/index.es.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/index.es.js"
    },
    "./wasm/*": "./lib/wasm/*"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build:workers": "tsc -p tsconfig.worker.json && node scripts/build-workers.js",
    "build": "tsc -b && pnpm build:workers && vite build && pnpm build:workers",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "pnpm asbuild:debug && pnpm asbuild:release",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.2.0",
    "assemblyscript": "^0.28.12",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sass": "^1.98.0",
    "terser": "^5.46.1",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-wasm": "^3.6.0"
  },
  "peerDependencies": {
    "@eggshell/ui-antd": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
