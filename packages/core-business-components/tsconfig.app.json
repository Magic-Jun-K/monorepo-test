{
  "extends": "../../tsconfig.client.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types", "./src/types"]
  },
  "include": [
    "src/**/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/types/**/*.d.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "plugins/**/*"
  ],
  "exclude": ["node_modules", "build", "public", "assembly"]
}
