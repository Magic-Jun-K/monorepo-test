{
  "extends": ["../../.oxlintrc.json"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "globals": {
    "React": "readonly",
    "JSX": "readonly"
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "*.config.js",
    "*.config.ts",
    "vite.config.ts"
  ],
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}