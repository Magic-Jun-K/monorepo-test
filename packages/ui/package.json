{
  "name": "@eggshell/ui",
  "version": "0.0.1",
  "description": "自定义 UI 组件库",
  "main": "index.ts",
  "module": "es/index.mjs",
  "types": "es/index.d.mts",
  "scripts": {
    "dev:ui": "tsup --watch",
    "build:ui": "tsup",
    "build:wasm": "cd src/components/Table/lib && wasm-pack build --target web --out-dir ../../../../pkg",
    "start:wasm": "cd src/components/Table/lib && wasm-pack build --target web --out-dir ../../../../pkg --dev --watch"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "6.1.14",
    "three": "0.172.0"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "0.172.0",
    "tsup": "8.3.6",
    "wasm-pack": "0.13.1",
    "@wasm-tool/wasm-pack-plugin": "1.7.0"
  },
  "keywords": [],
