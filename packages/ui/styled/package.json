{
  "name": "@eggshell/ui-styled",
  "version": "0.0.1",
  "description": "自定义 UI 组件库",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/canvaskit-test.git",
    "directory": "packages/ui/styled"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "main": "index.ts",
  "module": "es/index.mjs",
  "types": "es/index.d.mts",
  "scripts": {
    "dev:ui": "tsup --watch",
    "build:ui": "tsup",
    "build:wasm": "cd src/components/Table/lib && wasm-pack build --target web --out-dir ../../../../pkg",
    "start:wasm": "cd src/components/Table/lib && wasm-pack build --target web --out-dir ../../../../pkg --dev --watch",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "6.3.6"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@wasm-tool/wasm-pack-plugin": "1.7.0",
    "tsup": "^8.5.1",
    "wasm-pack": "0.13.1"
  }
}