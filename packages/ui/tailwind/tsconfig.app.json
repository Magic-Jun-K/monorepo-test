{
  "extends": "../../../tsconfig.client.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationDir": "lib/types",
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noUncheckedSideEffectImports": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "lib", "public"]
}
